/data/
/data_raw/
/processed/
/interim/
*.parquet
*.feather
*.duckdb
*.sqlite

# Cookies and credentials (NEVER commit)
*.cookies
.cookies/
*cookie*.txt
*.env
.env*
credentials*.json
secrets*

# The live scrape / ingest pipeline lives in the private repo — make sure
# nothing called refresh.py accidentally lands here.
**/refresh.py
**/refresh_and_rebuild.sh

# Claude Code / agent harness
.claude/settings.local.json
.claude/session*
.claude/projects/

